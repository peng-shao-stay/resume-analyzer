# DeepSeek API 配置
# 复制此文件为 .env 并填入你的 API Key
DEEPSEEK_API_KEY=your_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 缓存类型: memory（本地开发） / redis（生产环境）
CACHE_TYPE=memory

# Redis（CACHE_TYPE=redis 时需要）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=3600

# 文件上传限制
MAX_FILE_SIZE_MB=10
